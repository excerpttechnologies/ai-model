# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  Copy to .env and fill in your real keys.
#                  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Backend (choose one) ──────────────────────────────────────────────────
# Options: openai | nvidia | anthropic | local
# "openai" is the default and gives the best teaching output quality.
LLM_BACKEND=openai

# ── OpenAI (recommended) ──────────────────────────────────────────────────────
# Create a key at: https://platform.openai.com/api-keys
# IMPORTANT: Revoke and regenerate if ever exposed publicly.
OPENAI_API_KEY=sk-proj-...your-key-here...

# Model to use (gpt-4o gives best results, gpt-4o-mini is cheaper)
OPENAI_MODEL=gpt-4o

# ── NVIDIA Nemotron (alternative) ────────────────────────────────────────────
# Create a key at: https://integrate.api.nvidia.com
NVIDIA_API_KEY=nvapi-...your-key-here...

# ── Anthropic (fallback) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# ── ChromaDB path ─────────────────────────────────────────────────────────────
# Absolute path to your Chroma vector store folder.
# Run:  python ingest.py --source ./books --db ./curriculum_db
CURRICULUM_DB=./curriculum_db

# ── CORS origins ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Dev:  http://localhost:5173
# Prod: https://yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Server port (optional) ───────────────────────────────────────────────────
PORT=8090
